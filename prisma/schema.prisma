// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// User & Auth
// -----------------------------------------------------------------------------
model User {
  id         String  @id @default(uuid())
  username   String  @unique
  empNo      String? @unique @map("emp_no")
  name       String?
  email      String?
  position   String?
  department String?
  avatar     String?

  // Relations
  teamMembers   TeamMember[]
  tasksAssigned Task[]       @relation("TaskAssignee")
  taskComments  Comment[]
  createdTasks  Task[]       @relation("TaskCreator")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([id])
  @@map("users")
}

// -----------------------------------------------------------------------------
// Team & Project
// -----------------------------------------------------------------------------
model Team {
  id          String  @id @default(uuid())
  name        String
  description String?

  members  TeamMember[]
  projects Project[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([id])
  @@map("teams")
}

model TeamMember {
  id     String @id @default(uuid())
  userId String @map("user_id")
  teamId String @map("team_id")
  role   Role   @default(MEMBER) // ADMIN, MEMBER

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
  @@map("team_members")
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

model Project {
  id          String  @id @default(uuid())
  name        String
  description String?
  teamId      String

  team  Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  steps Step[] // คอลัมน์ต่างๆ ในโปรเจค (TODO, Dev, Test, Done, etc.)
  tasks Task[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([id])
  @@map("projects")
}

// -----------------------------------------------------------------------------
// Workflow & Tasks
// -----------------------------------------------------------------------------
// Step คือ คอลัมน์สถานะ (เช่น TODO, Dev, Test, Done) ให้จัดการได้ตามแต่ละ Project 
model Step {
  id        String @id @default(uuid())
  name      String
  order     Int
  projectId String @map("project_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, name])
  @@map("steps")
}

model Task {
  id      String  @id @default(uuid())
  title   String
  content String? @db.Text // เนื้อหา HTML จาก Rich Text Editor
  order   Float // ใช้สำหรับ Drag & Drop จัดลำดับในคอลัมน์

  // Relations
  projectId  String  @map("project_id")
  stepId     String  @map("step_id")
  assigneeId String? @map("assignee_id")
  creatorId  String  @map("creator_id")

  // Subtasks
  parentId String? @map("parent_id")
  parent   Task?   @relation("SubTasks", fields: [parentId], references: [id])
  subTasks Task[]  @relation("SubTasks")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  step     Step      @relation(fields: [stepId], references: [id])
  assignee User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator  User      @relation("TaskCreator", fields: [creatorId], references: [id])
  comments Comment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([id])
  @@map("tasks")
}

model Comment {
  id      String @id @default(uuid())
  content String @db.Text
  taskId  String @map("task_id")
  userId  String @map("user_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([id])
  @@map("comments")
}
